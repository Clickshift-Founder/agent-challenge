{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "cli"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "clickshift-alpha-agent",
      "args": {
        "cmd": [],
        "image": "emmanueliyke/clickshift-alpha:latest",
        "gpu": false,
        "expose": 3000,
        "env": {
          "PORT": "3000",
          "NODE_ENV": "production",
          "LOG_LEVEL": "info",
          "OPENAI_API_KEY": "YOUR_OPENAIKEY",
          "OPENAI_SMALL_MODEL": "gpt-4o-mini",
          "OPENAI_LARGE_MODEL": "gpt-4o-mini",
          "PGLITE_DATA_DIR": "/app/.eliza/.elizadb",
          "SOLANA_RPC_URL": "https://api.mainnet-beta.solana.com"
        }
      }
    }
  ]
}