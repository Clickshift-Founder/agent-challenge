# ══════════════════════════════════════════════════════════════
# ClickShift Alpha — Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── LLM Model Configuration ─────────────────────────────────
# Option A: Nosana-hosted endpoint (FREE — recommended for challenge)
# OLLAMA_API_URL=https://3yt39qx97wc9hqwwmylrphi4jsxrngjzxnjakkybnxbw.node.k8s.prd.nos.ci/api
OPENAI_API_KEY=mykey
MODEL_NAME_AT_ENDPOINT=gpt-4o-mini

# Option B: Local Ollama (for offline development)
# OLLAMA_API_URL=http://127.0.0.1:11434/api
# MODEL_NAME_AT_ENDPOINT=qwen3:0.6b

# Option C: OpenAI (if you have a key)
# OPENAI_API_KEY=sk-your-key-here

# ── Database ─────────────────────────────────────────────────
# PGLite — zero-config local PostgreSQL (recommended)
PGLITE_DATA_DIR=./.eliza/.elizadb

# ── Server ───────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=debug

# ── External APIs (for DeFi intelligence plugin) ─────────────
# RugCheck — no API key needed for basic usage
# DexScreener — no API key needed

# Solana RPC — use a fast RPC for production
# Free: https://api.mainnet-beta.solana.com
# Recommended: Helius (https://helius.dev) free tier
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Helius API key for enhanced Solana data
# HELIUS_API_KEY=your-helius-key-here
